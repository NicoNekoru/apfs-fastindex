<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparkle 2 appcast for apfs-fastindex.

  Lives on main; served at
  https://raw.githubusercontent.com/NicoNekoru/apfs-fastindex/main/appcast.xml
  (the URL hard-coded into Info.plist's SUFeedURL during build).

  The app polls this once a day in the background. Each <item>
  describes one release: version string, download URL, EdDSA
  signature (computed by `sign_update` against the .zip
  uploaded to the matching GitHub release), and zip length in
  bytes. Sparkle picks the highest version newer than the
  running app's CFBundleShortVersionString, verifies the
  signature against the public key embedded in Info.plist
  (SUPublicEDKey), downloads the zip, replaces the bundle, and
  restarts.

  `make-release.sh --publish` appends a new <item> here
  alongside the gh release upload. The maintainer commits the
  updated appcast.xml to main so the next user-side
  background-check sees the new release.

  Items are listed newest-first. Each item must have:

    <title>            human-readable version label
    <pubDate>          RFC 822 timestamp
    <sparkle:version>  the build-counter version
                       (matches CFBundleVersion)
    <sparkle:shortVersionString>
                       user-visible version
                       (matches CFBundleShortVersionString)
    <enclosure>        url, length (bytes), type
                       (application/octet-stream for zips),
                       sparkle:edSignature (from sign_update)

  Optional but recommended:

    <description>      release notes, plain text or HTML
                       (CDATA-wrapped if HTML)
    <sparkle:minimumSystemVersion>  macOS floor

  See https://sparkle-project.org/documentation/publishing/ for
  the full schema.
-->
<rss
    version="2.0"
    xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
    xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>apfs-fastindex updates</title>
        <link>https://github.com/NicoNekoru/apfs-fastindex</link>
        <description>Release feed for the apfs-fastindex macOS app.</description>
        <language>en</language>

        <item>
            <title>v0.2.3</title>
            <pubDate>Thu, 21 May 2026 02:07:50 +0000</pubDate>
            <sparkle:version>0.2.3</sparkle:version>
            <sparkle:shortVersionString>0.2.3</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <enclosure
                url="https://github.com/NicoNekoru/apfs-fastindex/releases/download/v0.2.3/ApfsFastindex-v0.2.3-macos-arm64.zip"
                length="2397683"
                type="application/octet-stream"
                sparkle:edSignature="3lAgxghAX3kmjA8F7WsxPWaQxOgP4si1j/nDr3lT4NkxS7nQS4SwH/bnspwAnLhx6U2k63UizwLgzzw3aC6/DQ=="
            />
        </item>

        <item>
            <title>v0.2.2</title>
            <pubDate>Thu, 21 May 2026 02:06:05 +0000</pubDate>
            <sparkle:version>0.2.2</sparkle:version>
            <sparkle:shortVersionString>0.2.2</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <enclosure
                url="https://github.com/NicoNekoru/apfs-fastindex/releases/download/v0.2.2/ApfsFastindex-v0.2.2-macos-arm64.zip"
                length="2397560"
                type="application/octet-stream"
                sparkle:edSignature="5hT2AAuqoojWbFDlTk7QFmD9HTFFkSbEwfKcv1aKpKYXJAS3S7HRK8/hYBgnL6x1up7Lt069PJ4+cQ6Rf/30BA=="
            />
        </item>
        <!--
          First real entry will be added by
          `make-release.sh --publish` once the maintainer has
          generated the EdDSA keypair (`sign_update
          --generate-keys`) and written the public key to
          `app/sparkle-public-key.txt`. Until then the channel is
          empty and Sparkle reports "no updates available" on
          every check — safe default.
        -->
    </channel>
</rss>
