<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Audit M2: `com.apple.security.automation.apple-events`
      removed. The original privileged-escalation path used
      `NSAppleScript`/`osascript`, which needed this entitlement.
      That flow was replaced with `AuthorizationServices`
      (`AdminSession.swift`) — no Apple events involved.
      `NSWorkspace.shared.open` and `LSOpenCFURLRef` paths
      don't require this entitlement either. Verified by grep:
      no `NSAppleScript` / `AESend` / `AEDetermine` references
      anywhere in the codebase.
    -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <!--
      Lets dyld load Sparkle.framework (and any other bundled
      third-party framework) under the hardened runtime when the
      main app and the framework are ad-hoc signed with mismatched
      Team IDs. Without this entitlement the hardened runtime's
      library validation rejects the framework with
      "code signature ... not valid for use in process: mapping
      process and mapped file (non-platform) have different Team
      IDs" — exactly what blocked the first Sparkle launch.

      Trade-off: any dylib in the bundle gets loaded without a
      same-Team-ID check. Acceptable for ad-hoc-signed builds
      (we control what ships in Contents/Frameworks). Builds
      signed with a real Developer ID can remove this entry and
      rely on matching team IDs instead.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
